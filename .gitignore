# Dados sensíveis e configurações locais
.env
scripts/config.json
scripts/*.json
!scripts/config.json.example

# Dados processados (gerados localmente, contém dados de chamados/negócio - não versionar)
data/

# Dumps/outputs temporários de sessão (dados de chamados/negócio)
/_*.txt

# Pacotes gerados por export-local-data.py
/dumps/

# Cache Python
__pycache__/
*.py[cod]
*$py.class
*.so

# Ambientes virtuais
venv/
env/
ENV/

# IDEs
.vscode/
.idea/
*.swp
*.swo

# Sistema operacional
.DS_Store
Thumbs.db
